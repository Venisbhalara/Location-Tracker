# ============================================================
#  RENDER DASHBOARD — Environment Variables Reference
#  Set ALL of these in Render > Your Service > Environment
# ============================================================

# ── Node ─────────────────────────────────────────────────────
PORT=5000                                  # Render sets this automatically; keep it here as fallback
NODE_ENV=production

# ── Database (Aiven MySQL / PlanetScale / Railway / etc.) ────
DB_HOST=your-db-host.example.com          # e.g. mysql-xxxxx.aivencloud.com
DB_PORT=3306                              # or 19174 for Aiven
DB_NAME=contact_tracker
DB_USER=your_db_username
DB_PASSWORD=your_db_password              # REQUIRED — server exits if missing

# ── Auth ─────────────────────────────────────────────────────
# Generate a strong secret:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_hex_secret        # REQUIRED — server exits if missing
JWT_EXPIRE=7d

# ── CORS — Frontend URLs ──────────────────────────────────────
# No trailing slash
CLIENT_URL=https://location-trackers.vercel.app
ADMIN_URL=https://location-trackers-admin.vercel.app
ALLOW_ALL_ORIGINS=false                   # keep false in production!

# ── Render keep-alive (self-ping every 14 min) ────────────────
RENDER_EXTERNAL_URL=https://location-tracker-n1p6.onrender.com

# ── Admin Bootstrap ───────────────────────────────────────────
SUPER_ADMIN_EMAIL=your_admin@email.com
SUPER_ADMIN_PASSWORD=your_strong_password
RESET_ADMIN_ON_START=false               # set true only to force-reset admin password

# ── Web Push (VAPID) ──────────────────────────────────────────
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:admin@yourdomain.com

# ── Google OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Email (optional — if not set, emails are mocked to console) ──
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# FROM_NAME=Location Tracker
# FROM_EMAIL=noreply@yourdomain.com
